<!DOCTYPE html>
<html lang="no">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Khanpro Transport - Kontakt</title>

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">

  <style>
    html,
    body {
      margin: 0;
      padding: 0;
      width: 100%;
      overflow-x: hidden;
    }

    body {
      font-family: 'Inter', sans-serif;
      background: #ffffff;
      color: #0b1220;
    }

    .kp-contact-modern,
    .kp-contact-modern * {
      box-sizing: border-box;
    }

    .kp-contact-modern {
      padding: 110px 32px;
      background: #ffffff;
      font-family: 'Inter', sans-serif;
      color: #0b1220;
      overflow: hidden;
    }

    .kp-contact-modern__inner {
      max-width: 1450px;
      margin: 0 auto;
      display: grid;
      grid-template-columns: minmax(0, 0.9fr) minmax(0, 1.1fr);
      gap: clamp(60px, 10vw, 190px);
      align-items: center;
    }

    .kp-contact-modern__eyebrow {
      display: inline-flex;
      align-items: center;
      margin-bottom: 18px;
      padding: 8px 14px;
      border-radius: 999px;
      background: rgba(11,18,32,0.06);
      color: rgba(11,18,32,0.7);
      font-size: 0.86rem;
      line-height: 1;
    }

    .kp-contact-modern h2 {
      margin: 0 0 22px;
      max-width: 640px;
      font-size: clamp(2.4rem, 4.6vw, 5rem);
      line-height: 0.98;
      letter-spacing: -0.06em;
      font-weight: 400;
      color: #050505;
    }

    .kp-contact-modern__content > p {
      margin: 0 0 34px;
      max-width: 560px;
      font-size: 1.05rem;
      line-height: 1.75;
      color: rgba(11,18,32,0.72);
    }

    .kp-contact-modern__info {
      display: grid;
      gap: 14px;
      max-width: 560px;
    }

    .kp-contact-modern__item {
      display: flex;
      align-items: center;
      gap: 18px;
      padding: 18px;
      border-radius: 18px;
      background: #ffffff;
      border: 1px solid rgba(11,18,32,0.08);
      text-decoration: none;
      color: #0b1220;
      box-shadow: 0 14px 34px rgba(11,18,32,0.06);
      transition: transform 0.3s ease, box-shadow 0.3s ease, border-color 0.3s ease;
    }

    .kp-contact-modern__item:hover {
      transform: translateY(-4px);
      box-shadow: 0 18px 40px rgba(11,18,32,0.12);
      border-color: rgba(11,18,32,0.16);
    }

    .kp-contact-modern__icon {
      flex: 0 0 58px;
      width: 58px;
      height: 58px;
      border-radius: 18px;
      display: flex;
      align-items: center;
      justify-content: center;
      background: #0b1220;
      color: #ffffff;
      font-size: 1.45rem;
    }

    .kp-contact-modern__item small {
      display: block;
      margin-bottom: 5px;
      font-size: 0.82rem;
      color: rgba(11,18,32,0.58);
    }

    .kp-contact-modern__item strong {
      display: block;
      font-size: 1rem;
      font-weight: 600;
      color: #0b1220;
      word-break: break-word;
    }

    .kp-contact-modern__actions {
      margin-top: 28px;
    }

    .kp-contact-modern__btn {
      min-height: 52px;
      border-radius: 999px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      padding: 0 30px;
      text-decoration: none;
      font-size: 0.94rem;
      font-weight: 500;
      transition: transform 0.3s ease, box-shadow 0.3s ease, background 0.3s ease;
    }

    .kp-contact-modern__btn--primary {
      background: #0b1220;
      color: #ffffff;
    }

    .kp-contact-modern__btn--primary:hover {
      transform: translateY(-3px);
      background: #111827;
      box-shadow: 0 16px 30px rgba(11,18,32,0.18);
    }

    .kp-contact-modern__visual {
      position: relative;
    }

    .kp-contact-modern__image {
      height: 620px;
      border-radius: 34px;
      overflow: hidden;
      box-shadow: 0 30px 80px rgba(11,18,32,0.16);
      background: #f3f4f6;
    }

    .kp-contact-modern__image img {
      width: 100%;
      height: 100%;
      display: block;
      object-fit: cover;
      object-position: center;
    }

    .kp-contact-modern__badge {
      position: absolute;
      left: -28px;
      bottom: 30px;
      padding: 18px 20px;
      border-radius: 20px;
      background: #0b1220;
      color: #ffffff;
      box-shadow: 0 18px 40px rgba(11,18,32,0.22);
    }

    .kp-contact-modern__badge strong {
      display: block;
      margin-bottom: 5px;
      font-size: 1rem;
      font-weight: 600;
    }

    .kp-contact-modern__badge span {
      display: block;
      font-size: 0.9rem;
      color: rgba(255,255,255,0.78);
    }

    .kp-contact-reveal {
      opacity: 0;
      transform: translateX(60px);
      transition: opacity 0.8s cubic-bezier(.2,.8,.2,1), transform 0.8s cubic-bezier(.2,.8,.2,1);
    }

    .kp-contact-reveal.is-visible {
      opacity: 1;
      transform: translateX(0);
    }

    .kp-contact-modern__visual.kp-contact-reveal {
      transition-delay: 0.14s;
    }

    @media (max-width: 1050px) {
      .kp-contact-modern {
        padding: 86px 24px;
      }

      .kp-contact-modern__inner {
        grid-template-columns: 1fr;
        gap: 44px;
      }

      .kp-contact-modern__image {
        height: 430px;
      }

      .kp-contact-modern__badge {
        left: 22px;
        bottom: 22px;
      }
    }

    @media (max-width: 680px) {
      .kp-contact-modern {
        padding: 64px 14px;
      }

      .kp-contact-modern__inner {
        gap: 28px;
      }

      .kp-contact-modern h2 {
        font-size: clamp(2rem, 10vw, 3rem);
        line-height: 1.02;
      }

      .kp-contact-modern__content > p {
        font-size: 0.96rem;
        line-height: 1.65;
      }

      .kp-contact-modern__item {
        padding: 14px;
        gap: 14px;
      }

      .kp-contact-modern__icon {
        flex-basis: 46px;
        width: 46px;
        height: 46px;
        border-radius: 14px;
        font-size: 1.18rem;
      }

      .kp-contact-modern__item strong {
        font-size: 0.94rem;
      }

      .kp-contact-modern__btn {
        width: 100%;
      }

      .kp-contact-modern__image {
        height: 260px;
        border-radius: 20px;
      }

      .kp-contact-modern__badge {
        left: 12px;
        right: 12px;
        bottom: 12px;
        padding: 12px 14px;
        border-radius: 16px;
      }

      .kp-contact-modern__badge strong {
        font-size: 0.92rem;
      }

      .kp-contact-modern__badge span {
        font-size: 0.82rem;
      }

      .kp-contact-reveal {
        transform: translateY(28px);
      }

      .kp-contact-reveal.is-visible {
        transform: translateY(0);
      }
    }

    @media (max-width: 380px) {
      .kp-contact-modern h2 {
        font-size: 1.9rem;
      }

      .kp-contact-modern__image {
        height: 230px;
      }
    }

    @media (prefers-reduced-motion: reduce) {
      .kp-contact-reveal,
      .kp-contact-modern__item,
      .kp-contact-modern__btn {
        transition: none !important;
        transform: none !important;
      }

      .kp-contact-reveal {
        opacity: 1 !important;
      }
    }
  </style>
</head>

<body>

  <section class="kp-contact-modern">
    <div class="kp-contact-modern__inner">

      <div class="kp-contact-modern__content kp-contact-reveal">
        <span class="kp-contact-modern__eyebrow">Kontakt oss</span>

        <h2>Vi hjelper deg gjerne med flyttingen</h2>

        <p>
          Har du spørsmål, ønsker pris eller vil avtale flyttehjelp? Ta kontakt med oss, så finner vi en trygg og effektiv løsning som passer ditt behov.
        </p>

        <div class="kp-contact-modern__info">
          <a href="mailto:post@khanprotransport.no" class="kp-contact-modern__item">
            <span class="kp-contact-modern__icon" aria-hidden="true">✉</span>
            <div>
              <small>E-post</small>
              <strong>post@khanprotransport.no</strong>
            </div>
          </a>

          <a href="tel:+4740610527" class="kp-contact-modern__item">
            <span class="kp-contact-modern__icon" aria-hidden="true">☎</span>
            <div>
              <small>Telefon</small>
              <strong>40 61 05 27</strong>
            </div>
          </a>
        </div>

        <div class="kp-contact-modern__actions">
          <a href="https://khanprotransport.no/kontakt-oss2" class="kp-contact-modern__btn kp-contact-modern__btn--primary">
            Kontakt oss
          </a>
        </div>
      </div>

      <div class="kp-contact-modern__visual kp-contact-reveal">
        <div class="kp-contact-modern__image">
          <img src="https://khanprotransport.no/onewebstatic/ChatGPT%20Image%208.%20mars%202026%2C%2017_47_01.png" alt="Khanpro Transport kundeservice">
        </div>

        <div class="kp-contact-modern__badge">
          <strong>Rask respons</strong>
          <span>Vi svarer så fort vi kan</span>
        </div>
      </div>

    </div>
  </section>

  <script>
    document.addEventListener('DOMContentLoaded', function () {
      const revealElements = document.querySelectorAll('.kp-contact-reveal');

      if (!('IntersectionObserver' in window)) {
        revealElements.forEach(el => el.classList.add('is-visible'));
        return;
      }

      const contactObserver = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
            contactObserver.unobserve(entry.target);
          }
        });
      }, {
        threshold: 0.2
      });

      revealElements.forEach(el => {
        contactObserver.observe(el);
      });
    });
  </script>

</body>
</html>
